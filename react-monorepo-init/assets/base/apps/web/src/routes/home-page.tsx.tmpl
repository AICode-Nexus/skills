import { ArrowRight, DatabaseZap, FormInput, Route } from "lucide-react";
import { Link } from "react-router-dom";

import { useDocumentTitle } from "{{SCOPE}}/hooks";
import { Button, Card, CardContent, CardHeader, CardTitle } from "{{SCOPE}}/ui";

import { PageHeader } from "../components/page-header";
import { useCounterStore } from "../features/counter/stores/use-counter-store";

const starterHighlights = [
  {
    title: "Routing shell",
    description: "Nested routes are already wired through React Router.",
    icon: Route,
    href: "/query",
  },
  {
    title: "Typed query demo",
    description: "TanStack Query comes with a ready-to-run async example.",
    icon: DatabaseZap,
    href: "/query",
  },
  {
    title: "Validated form demo",
    description: "React Hook Form and Zod are pre-wired for feature forms.",
    icon: FormInput,
    href: "/form",
  },
