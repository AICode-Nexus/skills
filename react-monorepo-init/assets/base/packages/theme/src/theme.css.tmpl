@theme {
  --color-background: oklch(0.98 0.01 255);
  --color-foreground: oklch(0.18 0.02 255);
  --color-surface: oklch(1 0 0);
  --color-border: oklch(0.91 0.01 255);
  --color-muted: oklch(0.95 0.01 255);
  --color-muted-foreground: oklch(0.47 0.02 255);
  --color-brand: oklch(0.61 0.2 254);
  --color-brand-foreground: oklch(0.98 0.01 255);
  --radius-sm: 0.5rem;
  --radius-md: 0.75rem;
  --radius-lg: 1rem;
  --font-sans: "IBM Plex Sans", "Inter", sans-serif;
}

:root {
  color-scheme: light;
}

body {
  background: var(--color-background);
  color: var(--color-foreground);
  font-family: var(--font-sans);
}
